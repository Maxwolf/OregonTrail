<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained, single-file publish profile for the headless bot.

  Lands OregonTrailDotNet.Bot.exe in the repo-root "publish" folder,
  alongside the game and minigames. Bundles the native SQLite runtime the
  bot shares with the game. MSBuild creates "publish" if it does not exist.

  CLI:  dotnet publish bot/OregonTrailDotNet.Bot/OregonTrailDotNet.Bot.csproj -p:PublishProfile=SelfContained
  Or run publish.ps1 in the repo root to publish all three at once.

  https://go.microsoft.com/fwlink/?LinkID=208121
-->
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <!-- Fold the native SQLite bundle (e_sqlite3) into the exe instead of dropping it beside it. -->
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- Trimming would strip the window/form/event types WolfCurses discovers by reflection. Leave it off. -->
    <PublishTrimmed>false</PublishTrimmed>
    <PublishReadyToRun>false</PublishReadyToRun>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <!-- Don't drag referenced projects' .pdb symbols into the publish folder. -->
    <PublishReferencesSymbols>false</PublishReferencesSymbols>
    <PublishDir>$(MSBuildThisFileDirectory)..\..\..\..\publish\</PublishDir>
  </PropertyGroup>

  <!--
    The bot references the game, which is itself an Exe project, so its runtimeconfig.json
    flows into publish output even though the bot's own copies are embedded in the single
    file. Strip those strays so the shared publish folder holds only the executables.
  -->
  <Target Name="TrimStrayPublishFiles" AfterTargets="ComputeFilesToPublish">
    <ItemGroup>
      <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)"
          Condition="'%(ResolvedFileToPublish.Extension)' == '.pdb'" />
      <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)"
          Condition="'%(ResolvedFileToPublish.Extension)' == '.json'
                     And ( $([System.String]::new('%(ResolvedFileToPublish.Filename)').EndsWith('.runtimeconfig'))
                           Or $([System.String]::new('%(ResolvedFileToPublish.Filename)').EndsWith('.deps')) )
                     And '%(ResolvedFileToPublish.Filename)' != '$(AssemblyName).runtimeconfig'
                     And '%(ResolvedFileToPublish.Filename)' != '$(AssemblyName).deps'" />
    </ItemGroup>
  </Target>
</Project>
