<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>OregonTrailDotNet.Bot</RootNamespace>
    <AssemblyName>OregonTrailDotNet.Bot</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="WolfCurses" Version="2026.7.15.8" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.10" />
    <!-- Pin the native SQLite bundle forward to 3.0.0, which patches the advisory (GHSA-2m69-gcr7-jv3q)
         that Microsoft.Data.Sqlite's transitive 2.1.11 carries. -->
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="3.0.3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\OregonTrailDotNet.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="OregonTrailDotNet.Bot.Tests" />
  </ItemGroup>

</Project>
