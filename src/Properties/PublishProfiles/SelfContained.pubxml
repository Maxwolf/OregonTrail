<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained, single-file publish profile for the game.

  Lands OregonTrailDotNet.exe in the repo-root "publish" folder so the game,
  minigames, and bot all sit side by side as one self-contained file each
  (no shared runtime, no loose native DLLs). MSBuild creates "publish" if
  it does not exist.

  CLI:  dotnet publish src/OregonTrailDotNet.csproj -p:PublishProfile=SelfContained
  Or run publish.ps1 in the repo root to publish all three at once.

  https://go.microsoft.com/fwlink/?LinkID=208121
-->
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <!-- Fold the native SQLite bundle (e_sqlite3) into the exe instead of dropping it beside it. -->
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- Trimming would strip the window/form/event types WolfCurses discovers by reflection. Leave it off. -->
    <PublishTrimmed>false</PublishTrimmed>
    <PublishReadyToRun>false</PublishReadyToRun>
    <!-- Keep the output folder to just the exes: no .pdb alongside the shipped build. -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <!-- Don't drag referenced projects' .pdb symbols into the publish folder. -->
    <PublishReferencesSymbols>false</PublishReferencesSymbols>
    <PublishDir>$(MSBuildThisFileDirectory)..\..\..\publish\</PublishDir>
  </PropertyGroup>

  <!--
    Referencing another project can drag that reference's runtimeconfig.json / .deps.json /
    .pdb into publish output, even though the entry app's own copies are embedded in the
    single file. Strip those strays so the shared publish folder holds only the executables.
  -->
  <Target Name="TrimStrayPublishFiles" AfterTargets="ComputeFilesToPublish">
    <ItemGroup>
      <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)"
          Condition="'%(ResolvedFileToPublish.Extension)' == '.pdb'" />
      <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)"
          Condition="'%(ResolvedFileToPublish.Extension)' == '.json'
                     And ( $([System.String]::new('%(ResolvedFileToPublish.Filename)').EndsWith('.runtimeconfig'))
                           Or $([System.String]::new('%(ResolvedFileToPublish.Filename)').EndsWith('.deps')) )
                     And '%(ResolvedFileToPublish.Filename)' != '$(AssemblyName).runtimeconfig'
                     And '%(ResolvedFileToPublish.Filename)' != '$(AssemblyName).deps'" />
    </ItemGroup>
  </Target>
</Project>
